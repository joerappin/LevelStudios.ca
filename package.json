{
  "name": "level-studio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"node server.js\"",
    "build": "vite build",
    "build:public": "vite build --config vite.public.config.js && mv dist-public/index.public.html dist-public/index.html",
    "build:app": "vite build --config vite.app.config.js && mv dist-app/index.app.html dist-app/index.html",
    "build:all": "npm run build:public && npm run build:app",
    "preview": "vite preview",
    "preview:public": "vite preview --config vite.public.config.js --outDir dist-public",
    "preview:app": "vite preview --config vite.app.config.js --outDir dist-app"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emailjs/browser": "^4.4.1",
    "@supabase/supabase-js": "^2.105.1",
    "archiver": "^7.0.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "firebase": "^12.12.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.460.0",
    "multer": "^1.4.5-lts.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "tailwind-merge": "^2.5.2"
  },
  "devDependencies": {
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "vite": "^5.4.8"
  }
}
